<?xml version="1.0"?>
<PropertyList>
 <generic>
  <input>
   <line_separator>newline</line_separator>
   <var_separator>,</var_separator>
   
   <!-- Motor RPMs (4 channels) -->
   <chunk>
    <name>motor_right</name>
    <type>double</type>
    <node>/apm/motor_right</node>
   </chunk>
   <chunk>
    <name>motor_left</name>
    <type>double</type>
    <node>/apm/motor_left</node>
   </chunk>
   <chunk>
    <name>motor_front</name>
    <type>double</type>
    <node>/apm/motor_front</node>
   </chunk>
   <chunk>
    <name>motor_back</name>
    <type>double</type>
    <node>/apm/motor_back</node>
   </chunk>
   
   <!-- Flight state (position/attitude) -->
   <chunk>
    <name>altitude</name>
    <type>double</type>
    <node>/apm/altitude</node>
   </chunk>
   <chunk>
    <name>roll</name>
    <type>double</type>
    <node>/apm/roll</node>
   </chunk>
   <chunk>
    <name>pitch</name>
    <type>double</type>
    <node>/apm/pitch</node>
   </chunk>
   <chunk>
    <name>heading</name>
    <type>double</type>
    <node>/apm/heading</node>
   </chunk>
   <chunk>
    <name>airspeed</name>
    <type>double</type>
    <node>/apm/airspeed</node>
   </chunk>
   
  </input>
 </generic>
</PropertyList>